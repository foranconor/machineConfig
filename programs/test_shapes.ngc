( test_shapes.ngc )
( mills 4 shapes across X, one per racked tool )
( stock: ~600mm x 120mm, ~20mm thick )
( G54: X0 Y0 at front-left corner of stock, Z0 at top surface )

M100                          ( pre-flight: abort if any tool not in rack )

G17 G21 G90 G54               ( XY plane, mm, absolute, work coords )
G0 Z20                        ( safe height )

( ================================================================ )
( T7 - 6mm upcut spiral: square pocket outline 60x60mm            )
( ================================================================ )
T7 M6
M03 S18000
G0 X20 Y20
G1 F2000 Z-3
G1 X80
G1 Y80
G1 X20
G1 Y20
G0 Z20

( ================================================================ )
( T12 - 12mm straight bit: arc/circle 50mm radius                 )
( ================================================================ )
T12 M6
M03 S16000
G0 X225 Y60                   ( center of arc )
G0 Z-3
G2 F1800 I-50 J0               ( full circle, 50mm radius )
G0 Z20

( ================================================================ )
( T3 - 3mm V-bit: three V-grooves 80mm long                       )
( ================================================================ )
T3 M6
M03 S20000
G0 X320 Y20
G1 F1200 Z-2
G1 Y100
G0 Z20
G0 X360 Y20
G1 F1200 Z-2
G1 Y100
G0 Z20
G0 X400 Y20
G1 F1200 Z-2
G1 Y100
G0 Z20

( ================================================================ )
( T19 - 20mm surfacing bit: serpentine facing passes 150x80mm     )
( ================================================================ )
T19 M6
M03 S12000
#<x_start> = 450
#<x_end>   = 600
#<y_start> = 10
#<y_end>   = 90
#<step>    = 18
#<radius>  = [#<step> / 2]
#<y>       = #<y_start>
#<dir>     = 1                ( 1 = going right, -1 = going left )

G0 X[#<x_start>] Y[#<y>]
G1 F4000 Z-1                  ( single plunge, stay at depth for all passes )

O200 while [#<y> LE #<y_end>]
  #<next_y> = [#<y> + #<step>]
  O210 if [#<dir> GT 0]
    G1 X[#<x_end>]
    O220 if [#<next_y> LE #<y_end>]
      G3 X[#<x_end>] Y[#<next_y>] I0 J[#<radius>]
    O220 endif
  O210 else
    G1 X[#<x_start>]
    O230 if [#<next_y> LE #<y_end>]
      G2 X[#<x_start>] Y[#<next_y>] I0 J[#<radius>]
    O230 endif
  O210 endif
  #<y>   = #<next_y>
  #<dir> = [#<dir> * -1]
O200 endwhile

G0 Z20

( ================================================================ )
M05
O<park> call
M30

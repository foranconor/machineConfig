( tool_change - motion sequence, called by Python M6 remap )
( rack positions: pocket 1-4 at X=100,200,300,400 Y=380 )
( #<next_pocket> and #<current_pocket> set by python/toplevel.py )
O<tool_change> sub

  #<rack_y>     = 380
  #<approach_y> = 300
  #<change_z>   = 50
  #<clear_z>    = 100
  #<dwell>      = 1
  #<feed>       = 3000

  #<current_x>  = [#<current_pocket> * 100]
  #<next_x>     = [#<next_pocket> * 100]

  M05
  G53 G0 Z[#<clear_z>]
  G49                                    ( cancel tool length offset before rack moves )

  O100 if [#<tool_in_spindle> GT 0]
    G53 G0 X[#<current_x>] Y[#<approach_y>]
    G53 G1 F[#<feed>] Z[#<change_z>]
    G53 G1 F[#<feed>] Y[#<rack_y>]
    G4 P[#<dwell>]
    G53 G0 Z[#<clear_z>]
  O100 endif

  G53 G0 X[#<next_x>] Y[#<rack_y>]
  G53 G1 F[#<feed>] Z[#<change_z>]
  G4 P[#<dwell>]
  G53 G0 Y[#<approach_y>]
  G53 G0 Z[#<clear_z>]
  M61 Q[#<next_tool>]
  G43 H[#<next_tool>]
O<tool_change> endsub [1]

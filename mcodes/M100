#!/usr/bin/env python3
# M100 - pre-flight tool check
# Place as first line of every program.
# Scans the program for T words and aborts if any tool has no rack position (P0).

import sys
import re
import os
import linuxcnc

stat = linuxcnc.stat()
stat.poll()

program_file = stat.file
if not program_file:
    sys.exit(0)

with open(program_file, 'r') as f:
    content = f.read()

# Strip comments before scanning for T words
clean = re.sub(r'\(.*?\)', '', content, flags=re.DOTALL)
clean = re.sub(r';[^\n]*', '', clean)
t_numbers = sorted(set(int(m) for m in re.findall(r'[Tt](\d+)', clean) if int(m) > 0))

# stat.tool_table doesn't expose pocket numbers in LinuxCNC 2.9 — parse the file directly
config_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
pocket_by_tool = {}
with open(os.path.join(config_dir, 'tools.tbl')) as f:
    for line in f:
        m = re.match(r'T(\d+)\s+P(\d+)', line.strip(), re.IGNORECASE)
        if m:
            pocket_by_tool[int(m.group(1))] = int(m.group(2))

errors = []
for t in t_numbers:
    if t not in pocket_by_tool:
        errors.append(f"  T{t} - not in tool table")
    elif pocket_by_tool[t] == 0:
        errors.append(f"  T{t} - not in rack (P0), load tool and update table")

if errors:
    print("PRE-FLIGHT FAILED:", file=sys.stderr)
    for e in errors:
        print(e, file=sys.stderr)
    sys.exit(1)

sys.exit(0)
